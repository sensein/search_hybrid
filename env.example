# Ontology Database Concept Mapping Tool - Environment Configuration

# ============================================================================
# Retrieval Configuration
# ============================================================================

# BM25 weight in hybrid retrieval (0.0-1.0, default: 0.3)
# Higher values favor exact keyword matches
BM25_WEIGHT=0.3

# Dense embedding weight in hybrid retrieval (0.0-1.0, default: 0.7)
# Higher values favor semantic similarity
DENSE_WEIGHT=0.7

# Dense embedding model name from Hugging Face
# Rich embeddings combine: preferred_label + definition + synonyms + labels + parent_labels
# Options:
#   - 'BAAI/bge-small-en-v1.5' (fast, 33M params, balanced quality — recommended default)
#   - 'sentence-transformers/all-MiniLM-L6-v2' (fastest, 22M params, lightweight)
#   - 'sentence-transformers/all-mpnet-base-v2' (better quality, 109M params)
#   - 'jinaai/jina-embeddings-v2-small-en' (optimized for search)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Vector search backend
# Options:
#   faiss  — recommended (exact cosine, builds in seconds from .npy, ~50ms search)
#             index is memory-mapped (IO_FLAG_MMAP) — no heap allocation, safe on low-RAM machines
#   numpy  — in-memory .npy, exact cosine, ~300ms search, no extra dependency
#   chroma — ChromaDB HNSW, NOT recommended (very slow build for >1M vectors)
VECTOR_BACKEND=faiss

# Only needed when VECTOR_BACKEND=chroma (not recommended for large datasets):
# CHROMA_DB_PATH=.cache/chroma_db

# ============================================================================
# Re-ranking Configuration
# ============================================================================

# Reranker type
# Single rerankers:
#   'llm'              — OpenRouter API (requires OPENROUTER_API_KEY)
#   'late_interaction' — ColBERT-like token MaxSim, fully local
#   'biomedical'       — keyword boost, fastest, fully local
# Dual ensembles (two rerankers, weights auto-normalised):
#   'dual_late'        — late_interaction + biomedical (local only, no API key needed)
#   'llm_late'         — llm + late_interaction
#   'llm_biomedical'   — llm + biomedical
# Triple ensemble:
#   'ensemble'         — all three (best quality)
RERANKER_TYPE=dual_late

# Ensemble re-ranker weights (applied after normalization)
LLM_WEIGHT=0.5
LATE_INTERACTION_WEIGHT=0.3
BIOMEDICAL_WEIGHT=0.2

# ============================================================================
# LLM Re-ranker Configuration (OpenRouter)
# ============================================================================
# Note: API key can also be passed via API request header or parameter

# OpenRouter API Key (required if using LLM reranker)
# Get free credits at: https://openrouter.ai/
# OPENROUTER_API_KEY=sk-or-v1-xxxxx

# OpenRouter Model (for semantic similarity scoring)
# Options:
#   - 'openrouter/auto' (auto-selects best available, default)
#   - 'google/gemini-2.0-flash-001' (fast, high quality)
#   - 'anthropic/claude-3.5-sonnet:beta' (highest quality, slower)
#   - 'meta-llama/llama-2-70b-chat' (open source)
#   - 'mistral/mistral-7b-instruct:free' (free tier)
OPENROUTER_MODEL=openrouter/auto

# Late-interaction model (ColBERT-like approach, local)
# Options:
#   - 'jinaai/jina-colbert-v2' (general purpose, default)
#   - 'jinaai/jina-colbert-v1' (older version)
LATE_INTERACTION_MODEL=jinaai/jina-colbert-v2

# ============================================================================
# Performance Configuration
# ============================================================================

# Maximum candidates to retrieve before re-ranking
# Higher values: better potential quality, slower
# Lower values: faster, may miss good candidates
MAX_CANDIDATES=20

# Maximum final results to return
# Per-API call limit
MAX_RESULTS=5

# Index cache directory (BM25 indexes)
# Pre-built BM25 indexes are stored here for faster startup
INDEX_CACHE_DIR=.cache/ontology_indexes

# Embedding cache directory (dense vector .npy files and FAISS indexes)
# Stores raw embeddings (.npy) and FAISS indexes — reused across restarts
EMBED_CACHE_DIR=.cache/embed_indexes

# Database path
DATABASE_PATH=bioportal.db

# ============================================================================
# API Configuration
# ============================================================================

# API host to bind to
API_HOST=0.0.0.0

# API port
API_PORT=8000

# Enable auto-reload in development
API_RELOAD=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Advanced Configuration
# ============================================================================

# Number of worker threads for concurrent requests
# Leave unset to auto-detect based on CPU cores
# WORKERS=4

# Request timeout in seconds
REQUEST_TIMEOUT=60

# GPU acceleration is auto-detected at startup (no manual config needed):
#   - Apple Silicon (MPS): used automatically if torch.backends.mps.is_available()
#   - NVIDIA GPU (CUDA): used automatically if torch.cuda.is_available()
#   - CPU fallback: used when neither MPS nor CUDA is available

# ============================================================================
# Pre-building Indexes (build_index.py)
# ============================================================================
# Run: python build_index.py
# Push to Hugging Face Hub: python build_index.py --push-to-hub org/repo-name
# Pull on another machine:  python build_index.py --pull-from-hub org/repo-name
# Requires: pip install huggingface_hub  (only for Hub push/pull)
